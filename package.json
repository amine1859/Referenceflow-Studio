{
  "name": "ref-flow-studio",
  "private": false,
  "version": "1.0.1",
  "description": "A Windows desktop reference-board app for artists, designers, and developers.",
  "author": "RefFlow Studio contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); for (const path of ['dist','server.js','dist_desktop']) fs.rmSync(path,{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "electron:dev": "cross-env NODE_ENV=development electron electron-main.cjs",
    "electron:start": "vite build && cross-env NODE_ENV=production electron electron-main.cjs",
    "electron:dist": "vite build && electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "idb-keyval": "^6.2.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "puppeteer": "^25.1.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.refflow.studio",
    "productName": "RefFlowStudio",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "electron-main.cjs",
      "installer.nsh",
      "package.json"
    ],
    "win": {
      "icon": "assets/referenceflow.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ReferenceFlow",
      "installerIcon": "assets/referenceflow.ico",
      "uninstallerIcon": "assets/referenceflow.ico",
      "include": "installer.nsh"
    }
  }
}
