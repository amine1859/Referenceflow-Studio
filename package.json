{
  "name": "ref-flow-studio",
  "productName": "RefFlowStudio",
  "private": false,
  "version": "2.0.0",
  "description": "A Windows desktop reference-board app for artists, designers, and developers.",
  "author": "RefFlow Studio contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); for (const path of ['dist','server.js','dist_desktop']) fs.rmSync(path,{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "test:office-ui": "node tools/verify-office-ui.cjs",
    "electron:dev": "cross-env NODE_ENV=development electron electron-main.cjs",
    "electron:start": "vite build && cross-env NODE_ENV=production electron electron-main.cjs",
    "electron:dist": "vite build && electron-builder --win --x64 --publish never",
    "electron:dist:unsigned": "vite build && electron-builder --win --x64 --publish never --config tools/electron-builder.unsigned.cjs",
    "electron:test-dist": "vite build && electron-builder --win --x64 --publish never --config tools/electron-builder.test.cjs",
    "update:metadata": "node tools/generate-update-metadata.cjs"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "electron-updater": "^6.8.5",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@google/genai": "^2.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "idb-keyval": "^6.2.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "puppeteer": "^25.1.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.refflow.studio",
    "productName": "RefFlowStudio",
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "dist_desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "amine1859",
        "repo": "Referenceflow-Studio"
      }
    ],
    "files": [
      "dist/**/*",
      "assets/**/*",
      "electron-main.cjs",
      "installer.nsh",
      "package.json"
    ],
    "win": {
      "icon": "assets/referenceflow.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ReferenceFlow",
      "installerIcon": "assets/referenceflow.ico",
      "uninstallerIcon": "assets/referenceflow.ico",
      "include": "installer.nsh"
    }
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  }
}
